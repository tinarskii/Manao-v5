{
  "name": "manao-v5",
  "module": "index.ts",
  "version": "5.0.0-alpha.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "dashboard",
    "setup"
  ],
  "scripts": {
    "start": "bun index",
    "format": "biome format --write .",
    "lint": "biome lint",
    "setup": "bun run setup/server/run.ts",
    "setup:build": "bun run --filter manao-setup build",
    "dashboard:build": "bun run --filter manao-dashboard build",
    "dashboard:dev": "bun run --filter manao-dashboard dev",
    "build": "bun run dashboard:build && bun run setup:build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@discordx/importer": "^1.3.3",
    "@elysiajs/static": "^1.4.7",
    "@manaobot/kick": "^1.1.3",
    "@manaobot/kickit": "^1.3.5",
    "@ngrok/ngrok": "^1.7.0",
    "@twurple/api": "^8.0.3",
    "@twurple/auth": "^8.0.3",
    "@twurple/chat": "^8.0.3",
    "@twurple/eventsub-ws": "^8.0.3",
    "discord.js": "^14.25.1",
    "discordx": "^11.13.3",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.27",
    "open": "^11.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zod": "^4.3.6"
  }
}
